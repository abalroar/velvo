# envs do servidor (vercel → project settings → environment variables).
# nenhuma delas tem prefixo NEXT_PUBLIC: ficam só no servidor, fora do browser.

# projeto supabase (settings → api)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # service role (secreta). nunca no client.

# opcional: trava /studio e as apis com basic auth (qualquer usuário + esta senha)
STUDIO_ACCESS_CODE=
